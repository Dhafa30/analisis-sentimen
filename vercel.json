{
  "builds": [
    {
      "src": "pln_sentiment/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/analyzer/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "pln_sentiment/wsgi.py"
    }
  ]
}
